/* Start Products */
.products {
    background-color: #ffffff;
}

.products .owl-carousel {
    padding-bottom: 70px;
}

.products .owl-carousel .owl-stage-outer {
    overflow: clip;
    overflow-x: hidden;
    padding-bottom: 52px;
}

.products .card {
    position: relative;
}

.products .card .image-container {
    height: 450px;
    overflow: hidden;
}

.products .card .image-container img {
    object-fit: cover;
    transition: all 0.5s ease-in-out;
}

.products .card:hover .image-container img {
    transform: scale(1.2);
}

.products .card h4 {
    font-size: 25px;
    line-height: 30px;
    margin: 0;
    color: #000;
}

.products .card:hover h4 {
    color: var(--color-primary-gold);
}

.products .card:hover h4 a {
    color: var(--color-primary-gold) !important;
}

.products .card h4 i {
    color: var(--color-primary-green);
    transition: all 0.5s ease-in-out;
    display: block;
    text-align: left;
    margin-top: 20px;
    display: none;
}

.products .card:hover h4 i {
    color: #fff;
}

.products .card p {
    display: none;
}

.products .owl-theme .owl-nav.disabled+.owl-dots {
    margin-top: 20px;
}

.products .owl-theme .owl-dots .owl-dot span {
    width: 15px;
    height: 15px;
    border-radius: 0;
}

.products .owl-theme .owl-dots .owl-dot.active span {
    background-color: var(--color-primary-green);
}

.page-products .card {
    margin-bottom: 75px !important;
}

/* End Products */

/* Start Banners */
.banners-2 .icon i {
    color: var(--color-primary-green);
}

.core-values .section-title {
    text-align: right;
    margin-bottom: 50px;
}

.core-values .section-title h1 {
    color: #fff;
    font-size: 50px;
}

.core-values .section-title p {
    font-size: 18px;
