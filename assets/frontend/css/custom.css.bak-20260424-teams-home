    background: linear-gradient(to bottom,
            rgb(0 0 0 / 85%) 0%,
            rgb(0 0 0 / 35%) 35%,
            rgba(0, 0, 0, 0.25) 70%,
            rgba(0, 0, 0, 0.55) 100%);
    filter: saturate(120%) contrast(105%);
    inset: 0;
    pointer-events: none;
}

#hero::after {
    background: transparent;
}

