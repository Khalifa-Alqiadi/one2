/* Start Slider */
.slider-swiper-home,
.slider-swiper-square,
.slider-swiper-rails {
    overflow: hidden;
}

.slider-swiper-home .swiper,
.slider-swiper-square .swiper,
.slider-swiper-rails .swiper {
    overflow: visible;
}

.section-title {
    text-align: right;
    padding-bottom: 10px;
    position: relative;
}

.section-title.section-title-with-line::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 5px;
    background-color: var(--color-primary-gold);
}

.section-title h2{
    font-size: 30px;
    padding-bottom: 10px;
}

.section-title h2::before,
.section-title h2::after {
    content: none;
}

.section-title h2 {
    margin: 0;
}

.section-title .section-title-btn {
    color: var(--color-primary-gold);
    font-size: 16px;
}

.slider-swiper-home .card,
.slider-swiper-square .card {
    aspect-ratio: 16 / 9;
    width: 100%;
}

.slider-swiper-home .card,
.slider-swiper-square .card,
.slider-swiper-rails .card {
    padding: 0;
    border: 0;
    position: relative;
    overflow: hidden;
}

.slider-swiper-home .video-container {
    height: 100%;
}

.slider-swiper-home .video-container img,
.slider-swiper-square .video-container img,
.slider-swiper-rails .video-container img {
    height: 100%;
    width: 100%;
    object-fit: cover;
}

.slider-swiper-home .card .card-body,
.slider-swiper-rails .card .card-body,
.slider-swiper-home .card::after,
.slider-swiper-square .card .card-body,
.slider-swiper-square .card::after,
.slider-swiper-rails .card::after {
    position: absolute;
    bottom: -50%;
    right: 0;
    width: 100%;
    transition: all 0.7s ease-in-out;
    z-index: 1;
}

.slider-swiper-home .card::after,
.slider-swiper-square .card::after,
.slider-swiper-rails .card::after {
    box-shadow: 0 0 80px 100px #000;
    z-index: 0;
    content: "";
}

.slider-swiper-home .card:hover .card-body,
.slider-swiper-square .card:hover .card-body,
.slider-swiper-square .card:hover::after,
.slider-swiper-home .card:hover::after {
    bottom: 0;
}

.slider-swiper-rails .card .card-body,
.slider-swiper-rails .card::after {
    bottom: 0;
}

.slider-swiper-home .card .badge,
.slider-swiper-square .card .badge,
.slider-swiper-rails .card .badge {
    background-color: var(--color-primary-gold);
    color: #fff;
    width: 35px;
    height: 35px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
}

.slider-swiper-rails .badge {
    display: none;
}

.slider-swiper-home .card .badge i,
.slider-swiper-square .card .badge i,
.slider-swiper-rails .card .badge i {
    font-size: 15px !important;
}

.slider-swiper-rails .card .badge {
    display: none !important;
}

.slider-swiper-home .card h4,
.slider-swiper-square .card h4,
.slider-swiper-rails .card h4 {
    font-size: 18px;
    line-height: 28px;
}

.slider-swiper-rails .video-container {
    position: relative;
    width: 100%;
    max-width: 360px;
    aspect-ratio: 9 / 16;
}

.slider-swiper-home .swiper-button-next,
.slider-swiper-home .swiper-button-prev,
.slider-swiper-square .swiper-button-next,
.slider-swiper-square .swiper-button-prev,
.slider-swiper-rails .swiper-button-next,
.slider-swiper-rails .swiper-button-prev {
    background-color: #282828cc;
    padding: 10px;
    font-size: 20px;
    width: 48px;
    height: 70px;
    color: var(--color-primary-gold);
}

.slider-swiper-home .swiper-button-prev,
.slider-swiper-home .swiper-rtl .swiper-button-next,
.slider-swiper-square .swiper-button-prev,
.slider-swiper-square .swiper-rtl .swiper-button-next,
.slider-swiper-rails .swiper-button-prev,
.slider-swiper-rails .swiper-rtl .swiper-button-next {
    left: 0;
    right: auto;
}

.slider-swiper-home .swiper-button-prev,
.slider-swiper-home .swiper-rtl .swiper-button-next,
.slider-swiper-square .swiper-button-prev,
.slider-swiper-square .swiper-rtl .swiper-button-next,
.slider-swiper-rails .swiper-button-prev,
.slider-swiper-rails .swiper-rtl .swiper-button-next {
    left: -70px;
    right: auto;
}

.slider-swiper-home .swiper-button-next,
.slider-swiper-home .swiper-rtl .swiper-button-prev,
.slider-swiper-square .swiper-button-next,
.slider-swiper-square .swiper-rtl .swiper-button-prev,
.slider-swiper-rails .swiper-button-next,
.slider-swiper-rails .swiper-rtl .swiper-button-prev {
    right: -70px;
    left: auto;
}

.slider-swiper-home .swiper-button-next:after,
.slider-swiper-home .swiper-rtl .swiper-button-prev:after,
.slider-swiper-square .swiper-button-next:after,
.slider-swiper-square .swiper-rtl .swiper-button-prev:after,
.slider-swiper-rails .swiper-button-next:after,
.slider-swiper-rails .swiper-rtl .swiper-button-prev:after {
    color: var(--color-primary-gold);
    font-size: 30px;
}

.swiper-pagination-main {
    position: relative;
    text-align: left;
    justify-content: end;
    flex-direction: row-reverse;
}

.swiper-pagination-main::after {
    left: -6%;
    top: 58%;
    transform: translateY(-50%);
    background-color: #fff;
    height: 3px;
    width: 5%;
    content: "";
    position: absolute;
}

.swiper-pagination {
    position: relative;
    text-align: left;
    width: auto !important;
    bottom: 0 !important;
}

.swiper-pagination .swiper-pagination-bullet {
    width: 20px;
    height: 5px;
    border-radius: 4px;
    background-color: #fff;
    transition: all 0.4s ease-in-out;
}

.swiper-pagination .swiper-pagination-bullet:hover,
.swiper-pagination .swiper-pagination-bullet.swiper-pagination-bullet-active {
    width: 50px;
    background-color: var(--color-primary-gold);
}

.slider-swiper-square .video-container {
    height: 100%;
}

/* End Slider */

