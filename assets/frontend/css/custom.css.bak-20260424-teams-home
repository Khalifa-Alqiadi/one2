}

#hero::after,
.breadcrumbs::after {
    content: "";
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1;
    position: absolute;
    /*background-color: var(--color-primary-gold);*/
    /*background: var(--linear-gradient);*/
