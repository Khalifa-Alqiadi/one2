/* Start Topic Page */
.topic-page {
    position: relative;
}

.topic-page .bottom-article {
    border: 0;
    padding: 0;
    background-color: transparent !important;
    position: absolute;
    right: 0;
    z-index: 1;
    top: -40px;
}

.topic-page .bottom-article .social-network {
    visibility: hidden;
    width: 0;
    transition: all 0.5s ease-in-out;
}

.topic-page .bottom-article .social-network.active {
    visibility: visible;
    width: 100%;
}

.topic-page .share-title {
    font-size: 35px;
    margin-right: 10px;
    color: #000;
    cursor: pointer;
}

.topic-page .share-title i {
    color: #fff;
}

.topic-page h1 {
    color: #fff;
    margin-top: 30px;
}

.topic-page .video-short {
    position: relative;
    width: min(var(--maxW), 100%);
    aspect-ratio: 9 / 16;
    border-radius: var(--radius);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: var(--shadow);
    overflow: hidden;
}

.topic-page .video-short iframe {
    position: absolute;
    width: 100%;
    height: 100%;
    border: 0;
}

.topic-page .meta {
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.topic-page .top-line {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
}

.topic-page .title {
    font-size: 14px;
    font-weight: 800;
    line-height: 1.35;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.topic-page .channel {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 6px;
    color: var(--muted);
    font-size: 12px;
}

.topic-page .avatar {
    width: 34px;
    height: 34px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.16);
    flex: 0 0 auto;
    overflow: hidden;
}

.topic-page .avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.topic-page .video-short .chips {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
}

.topic-page .video-short .chip {
    background: var(--chip);
    border: 1px solid rgba(255, 255, 255, 0.12);
    padding: 6px 10px;
    border-radius: 999px;
    font-size: 12px;
    color: var(--text);
}

/* لو حبيت أزرار يمين مثل يوتيوب (UI فقط) */
.topic-page .video-short .actions {
    position: absolute;
    left: 12px;
    bottom: 90px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    z-index: 3;
    pointer-events: none;
}

.topic-page .video-short .action {
    width: 46px;
    height: 46px;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid rgba(255, 255, 255, 0.14);
    display: grid;
    place-items: center;
    color: #fff;
    backdrop-filter: blur(6px);
    pointer-events: auto;
    cursor: pointer;
    user-select: none;
}

.topic-page .video-short .actions {
    position: absolute;
    left: 12px;
    bottom: 90px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    z-index: 3;
}

.topic-page .video-short .action {
    width: 52px;
    min-height: 52px;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid rgba(255, 255, 255, 0.14);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    color: #fff;
    backdrop-filter: blur(6px);
    cursor: pointer;
    user-select: none;
    padding: 8px 6px;
}

.topic-page .video-short .action .count {
    font-size: 12px;
    opacity: 0.85;
}

/* Toast */
.topic-page .video-short .toast {
    position: fixed;
    bottom: 18px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0, 0, 0, 0.75);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: #fff;
    padding: 10px 12px;
    border-radius: 999px;
    font-size: 13px;
    opacity: 0;
    pointer-events: none;
    transition: 0.2s ease;
    z-index: 999;
}

.topic-page .video-short .toast.show {
    opacity: 1;
}

/* Modal */
.topic-page .video-short .modal {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    display: none;
    place-items: center;
    padding: 14px;
    z-index: 999;
}

.topic-page .video-short .modal.open {
    display: grid;
}

.topic-page .video-short .modal-card {
    width: min(520px, 100%);
    background: #141414;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 18px;
    overflow: hidden;
}

.topic-page .video-short .modal-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 14px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

.topic-page .video-short .modal-head .x {
    background: transparent;
    border: 0;
    color: #fff;
    font-size: 18px;
    cursor: pointer;
}

.topic-page .video-short .modal-body {
    max-height: 50vh;
    overflow: auto;
    padding: 12px 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.topic-page .video-short .comment {
    padding: 10px 12px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    font-size: 13px;
    line-height: 1.4;
}

.topic-page .video-short .modal-foot {
    display: flex;
    gap: 10px;
    padding: 12px 14px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
}

.topic-page .video-short .modal-foot input {
    flex: 1;
    padding: 10px 12px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(0, 0, 0, 0.25);
    color: #fff;
    outline: none;
}

.topic-page .video-short .modal-foot button {
    padding: 10px 14px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    cursor: pointer;
    font-weight: 800;
}

.topic-page .video-youtube {
    aspect-ratio: 16 / 9;
}

.topic-page .video-youtube iframe {
    height: 100% !important;
}

.topic-page .side-video .card .card-header {
    width: 40%;
}

.topic-page .side-video .card .card-body {
    width: 60%;
}

.topic-page .side-video .card h4 {
    font-size: 19px;
    line-height: 29px;
}

