:root {
    /* ===== Primary Colors ===== */
    --color-primary-gold: #edbb26;

    /* ===== Neutral Colors ===== */
    --color-white: #f8f9f8;
    /* أبيض */
    --linear-gradient: linear-gradient(to bottom,
            rgba(220, 170, 0, 0.85) 0%,
            rgba(220, 170, 0, 0.35) 35%,
            rgba(0, 0, 0, 0.25) 70%,
            rgba(0, 0, 0, 0.55) 100%);
    --maxW: 420px;
    --bg: #242424;
    --card: #242424;
    --text: #f1f1f1;
    --muted: #bdbdbd;
    --chip: rgba(255, 255, 255, 0.1);
    --radius: 18px;
    --shadow: 0 10px 30px rgba(0, 0, 0, 0.45);
    --line: rgba(255, 255, 255, 0.08);
    --gold-soft: rgba(212, 175, 55, 0.14);
    --text: #f5f7fb;
    --surface: #171922;
    --surface-2: #1d202b;
}

@media (min-width: 1400px) {

    .container,
    .container-lg,
    .container-md,
    .container-sm,
